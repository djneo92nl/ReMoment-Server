APP_NAME=ReMoment
APP_ENV=production
APP_KEY={{ vault_app_key }}
APP_DEBUG=false
APP_URL={{ app_url }}

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

MQTT_HOST={{ mqtt_host }}
MQTT_PORT={{ mqtt_port }}
MQTT_CLIENT_ID={{ mqtt_client_id }}

# Used by Docker Compose for volume permission matching
WWWUSER={{ app_uid }}
WWWGROUP={{ app_gid }}
APP_PORT={{ app_port }}
